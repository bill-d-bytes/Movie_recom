# Copy to .env and fill in values. Never commit .env to version control.
SECRET_KEY=change-me-to-a-long-random-string
TMDB_API_KEY=
# Optional: minimum release year for the Discover “2000 to present” TMDb row (default 2000)
# TMDB_MODERN_MIN_YEAR=2000
# In production over HTTPS, set to 1 so the session cookie is only sent on HTTPS
# SESSION_COOKIE_SECURE=1
# Log API requests slower than this many ms (e.g. 2000) — optional performance monitoring
# CINEMATCH_LOG_SLOW_API_MS=2000
